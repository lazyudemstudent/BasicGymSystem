@model Cliente
@{ ViewData["Title"] = "Detalle del cliente"; }
<div class="card shadow-sm"><div class="card-header"><h2 class="h4 mb-0">Detalle del cliente</h2></div><div class="card-body"><dl class="row details-list"><dt class="col-sm-3">Cédula</dt><dd class="col-sm-9">@Model.Cedula</dd><dt class="col-sm-3">Nombre completo</dt><dd class="col-sm-9">@Model.NombreCompleto</dd><dt class="col-sm-3">Teléfono</dt><dd class="col-sm-9">@Model.Telefono</dd><dt class="col-sm-3">Correo</dt><dd class="col-sm-9">@Model.Correo</dd><dt class="col-sm-3">Fecha de nacimiento</dt><dd class="col-sm-9">@Model.FechaNacimiento.ToString("dd/MM/yyyy")</dd><dt class="col-sm-3">Fecha de registro</dt><dd class="col-sm-9">@Model.FechaRegistro.ToString("dd/MM/yyyy")</dd><dt class="col-sm-3">Entrenador</dt><dd class="col-sm-9">@(Model.Entrenador?.NombreCompleto ?? "Sin asignar")</dd><dt class="col-sm-3">Estado</dt><dd class="col-sm-9">@(Model.Activo ? "Activo" : "Inactivo")</dd></dl><a asp-action="Edit" asp-route-id="@Model.ClienteId" class="btn btn-primary">Editar</a> <a asp-action="Index" class="btn btn-outline-secondary">Volver</a></div></div>
