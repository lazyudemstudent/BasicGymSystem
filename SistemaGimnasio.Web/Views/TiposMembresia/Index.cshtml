@model IEnumerable<TipoMembresia>
@{ ViewData["Title"] = "Planes de membresía"; }
<div class="card shadow-sm"><div class="card-header d-flex justify-content-between align-items-center"><div><h2 class="h4 mb-0">Planes de membresía</h2><small class="text-muted">Catálogo de planes disponibles</small></div><a asp-action="Create" class="btn btn-primary">Nuevo plan</a></div><div class="card-body"><div class="table-responsive"><table class="table table-striped table-hover"><thead><tr><th>Nombre</th><th>Duración</th><th>Precio</th><th>Estado</th><th></th></tr></thead><tbody>@foreach (var item in Model) { <tr><td>@item.Nombre</td><td>@item.DuracionDias días</td><td>@item.Precio.ToString("C2")</td><td><span class="badge @(item.Activa ? "bg-success" : "bg-secondary")">@(item.Activa ? "Activa" : "Inactiva")</span></td><td class="action-buttons text-end"><a asp-action="Details" asp-route-id="@item.TipoMembresiaId" class="btn btn-sm btn-outline-secondary">Detalles</a> <a asp-action="Edit" asp-route-id="@item.TipoMembresiaId" class="btn btn-sm btn-outline-primary">Editar</a> <a asp-action="Delete" asp-route-id="@item.TipoMembresiaId" class="btn btn-sm btn-outline-danger">Eliminar</a></td></tr> }</tbody></table></div>@if (!Model.Any()) { <div class="text-center text-muted py-4">No hay planes registrados.</div> }</div></div>
