@model TipoMembresia
@{ ViewData["Title"] = "Detalle del plan"; }
<div class="card shadow-sm"><div class="card-header"><h2 class="h4 mb-0">Detalle del plan</h2></div><div class="card-body"><dl class="row details-list"><dt class="col-sm-3">Nombre</dt><dd class="col-sm-9">@Model.Nombre</dd><dt class="col-sm-3">Descripción</dt><dd class="col-sm-9">@Model.Descripcion</dd><dt class="col-sm-3">Duración</dt><dd class="col-sm-9">@Model.DuracionDias días</dd><dt class="col-sm-3">Precio</dt><dd class="col-sm-9">@Model.Precio.ToString("C2")</dd><dt class="col-sm-3">Estado</dt><dd class="col-sm-9">@(Model.Activa ? "Activa" : "Inactiva")</dd><dt class="col-sm-3">Membresías asociadas</dt><dd class="col-sm-9">@Model.Membresias.Count</dd></dl><a asp-action="Edit" asp-route-id="@Model.TipoMembresiaId" class="btn btn-primary">Editar</a> <a asp-action="Index" class="btn btn-outline-secondary">Volver</a></div></div>
