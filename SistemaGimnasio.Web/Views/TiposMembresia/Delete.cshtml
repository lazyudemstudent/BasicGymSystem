@model TipoMembresia
@{ ViewData["Title"] = "Eliminar plan"; }
<div class="card shadow-sm border-danger"><div class="card-header"><h2 class="h4 mb-0 text-danger">Eliminar plan</h2></div><div class="card-body"><p>¿Está seguro de eliminar el plan <strong>@Model.Nombre</strong>?</p><p class="text-muted">No podrá eliminarse si está asociado a una membresía.</p><form asp-action="Delete" method="post"><input type="hidden" asp-for="TipoMembresiaId" /><button type="submit" class="btn btn-danger">Eliminar</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></form></div></div>
