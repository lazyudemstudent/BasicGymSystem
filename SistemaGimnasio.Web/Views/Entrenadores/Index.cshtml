@model IEnumerable<Entrenador>
@{
    ViewData["Title"] = "Entrenadores";
}
<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <div><h2 class="h4 mb-0">Entrenadores</h2><small class="text-muted">Gestión de entrenadores del gimnasio</small></div>
        <a asp-action="Create" class="btn btn-primary">Nuevo entrenador</a>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead><tr><th>Cédula</th><th>Nombre</th><th>Especialidad</th><th>Teléfono</th><th>Estado</th><th></th></tr></thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Cedula</td><td>@item.NombreCompleto</td><td>@item.Especialidad</td><td>@item.Telefono</td>
                        <td><span class="badge @(item.Activo ? "bg-success" : "bg-secondary")">@(item.Activo ? "Activo" : "Inactivo")</span></td>
                        <td class="action-buttons text-end"><a asp-action="Details" asp-route-id="@item.EntrenadorId" class="btn btn-sm btn-outline-secondary">Detalles</a> <a asp-action="Edit" asp-route-id="@item.EntrenadorId" class="btn btn-sm btn-outline-primary">Editar</a> <a asp-action="Delete" asp-route-id="@item.EntrenadorId" class="btn btn-sm btn-outline-danger">Eliminar</a></td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
        @if (!Model.Any()) { <div class="text-center text-muted py-4">No hay entrenadores registrados.</div> }
    </div>
</div>
