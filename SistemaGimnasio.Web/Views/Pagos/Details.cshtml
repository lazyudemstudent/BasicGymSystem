@model Pago
@{ ViewData["Title"] = "Detalle del pago"; }
<div class="card shadow-sm"><div class="card-header"><h2 class="h4 mb-0">Detalle del pago</h2></div><div class="card-body"><dl class="row details-list"><dt class="col-sm-3">Cliente</dt><dd class="col-sm-9">@Model.Membresia?.Cliente?.NombreCompleto</dd><dt class="col-sm-3">Plan</dt><dd class="col-sm-9">@Model.Membresia?.TipoMembresia?.Nombre</dd><dt class="col-sm-3">Fecha de pago</dt><dd class="col-sm-9">@Model.FechaPago.ToString("dd/MM/yyyy")</dd><dt class="col-sm-3">Monto</dt><dd class="col-sm-9">@Model.Monto.ToString("C2")</dd><dt class="col-sm-3">Método</dt><dd class="col-sm-9">@Model.MetodoPago</dd><dt class="col-sm-3">Referencia</dt><dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Referencia) ? "-" : Model.Referencia)</dd><dt class="col-sm-3">Observación</dt><dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Observacion) ? "-" : Model.Observacion)</dd></dl><a asp-action="Edit" asp-route-id="@Model.PagoId" class="btn btn-primary">Editar</a> <a asp-action="Index" class="btn btn-outline-secondary">Volver</a></div></div>
