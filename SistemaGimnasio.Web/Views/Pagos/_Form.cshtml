@model Pago
<div class="row g-3"><div class="col-md-6"><label asp-for="MembresiaId" class="form-label"></label><select asp-for="MembresiaId" class="form-select" asp-items="ViewBag.MembresiaId"><option value="">Seleccione una membresía</option></select><span asp-validation-for="MembresiaId"></span></div><div class="col-md-3"><label asp-for="FechaPago" class="form-label"></label><input asp-for="FechaPago" type="date" class="form-control" /><span asp-validation-for="FechaPago"></span></div><div class="col-md-3"><label asp-for="Monto" class="form-label"></label><input asp-for="Monto" class="form-control" /><span asp-validation-for="Monto"></span></div><div class="col-md-4"><label asp-for="MetodoPago" class="form-label"></label><select asp-for="MetodoPago" class="form-select"><option value="Efectivo">Efectivo</option><option value="Tarjeta">Tarjeta</option><option value="Transferencia">Transferencia</option></select><span asp-validation-for="MetodoPago"></span></div><div class="col-md-8"><label asp-for="Referencia" class="form-label"></label><input asp-for="Referencia" class="form-control" placeholder="Opcional" /><span asp-validation-for="Referencia"></span></div><div class="col-12"><label asp-for="Observacion" class="form-label"></label><textarea asp-for="Observacion" class="form-control" rows="3"></textarea><span asp-validation-for="Observacion"></span></div></div>
