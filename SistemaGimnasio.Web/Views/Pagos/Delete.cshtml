@model Pago
@{ ViewData["Title"] = "Eliminar pago"; }
<div class="card shadow-sm border-danger"><div class="card-header"><h2 class="h4 mb-0 text-danger">Eliminar pago</h2></div><div class="card-body"><p>¿Está seguro de eliminar el pago de <strong>@Model.Monto.ToString("C2")</strong> realizado por <strong>@Model.Membresia?.Cliente?.NombreCompleto</strong>?</p><form asp-action="Delete" method="post"><input type="hidden" asp-for="PagoId" /><button type="submit" class="btn btn-danger">Eliminar</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></form></div></div>
