@model IEnumerable<Pago>
@{ ViewData["Title"] = "Pagos"; }
<div class="card shadow-sm"><div class="card-header d-flex justify-content-between align-items-center"><div><h2 class="h4 mb-0">Pagos</h2><small class="text-muted">Historial de pagos de membresías</small></div><a asp-action="Create" class="btn btn-primary">Registrar pago</a></div><div class="card-body"><div class="table-responsive"><table class="table table-striped table-hover"><thead><tr><th>Fecha</th><th>Cliente</th><th>Plan</th><th>Monto</th><th>Método</th><th>Referencia</th><th></th></tr></thead><tbody>@foreach (var item in Model) { <tr><td>@item.FechaPago.ToString("dd/MM/yyyy")</td><td>@item.Membresia?.Cliente?.NombreCompleto</td><td>@item.Membresia?.TipoMembresia?.Nombre</td><td>@item.Monto.ToString("C2")</td><td>@item.MetodoPago</td><td>@(string.IsNullOrWhiteSpace(item.Referencia) ? "-" : item.Referencia)</td><td class="action-buttons text-end"><a asp-action="Details" asp-route-id="@item.PagoId" class="btn btn-sm btn-outline-secondary">Detalles</a> <a asp-action="Edit" asp-route-id="@item.PagoId" class="btn btn-sm btn-outline-primary">Editar</a> <a asp-action="Delete" asp-route-id="@item.PagoId" class="btn btn-sm btn-outline-danger">Eliminar</a></td></tr> }</tbody></table></div>@if (!Model.Any()) { <div class="text-center text-muted py-4">No hay pagos registrados.</div> }</div></div>
