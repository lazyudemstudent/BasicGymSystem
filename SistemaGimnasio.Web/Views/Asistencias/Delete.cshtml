@model Asistencia
@{ ViewData["Title"] = "Eliminar asistencia"; }
<div class="card shadow-sm border-danger"><div class="card-header"><h2 class="h4 mb-0 text-danger">Eliminar asistencia</h2></div><div class="card-body"><p>¿Está seguro de eliminar la asistencia de <strong>@Model.Cliente?.NombreCompleto</strong> del @Model.FechaHoraEntrada.ToString("dd/MM/yyyy HH:mm")?</p><form asp-action="Delete" method="post"><input type="hidden" asp-for="AsistenciaId" /><button type="submit" class="btn btn-danger">Eliminar</button> <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a></form></div></div>
