@model IEnumerable<Asistencia>
@{ ViewData["Title"] = "Asistencias"; }
<div class="card shadow-sm"><div class="card-header d-flex justify-content-between align-items-center"><div><h2 class="h4 mb-0">Asistencias</h2><small class="text-muted">Registro de entradas y salidas</small></div><a asp-action="Create" class="btn btn-primary">Registrar asistencia</a></div><div class="card-body"><div class="table-responsive"><table class="table table-striped table-hover"><thead><tr><th>Cliente</th><th>Entrada</th><th>Salida</th><th>Observación</th><th></th></tr></thead><tbody>@foreach (var item in Model) { <tr><td>@item.Cliente?.NombreCompleto</td><td>@item.FechaHoraEntrada.ToString("dd/MM/yyyy HH:mm")</td><td>@(item.FechaHoraSalida.HasValue ? item.FechaHoraSalida.Value.ToString("dd/MM/yyyy HH:mm") : "Pendiente")</td><td>@(string.IsNullOrWhiteSpace(item.Observacion) ? "-" : item.Observacion)</td><td class="action-buttons text-end"><a asp-action="Details" asp-route-id="@item.AsistenciaId" class="btn btn-sm btn-outline-secondary">Detalles</a> <a asp-action="Edit" asp-route-id="@item.AsistenciaId" class="btn btn-sm btn-outline-primary">Editar</a> <a asp-action="Delete" asp-route-id="@item.AsistenciaId" class="btn btn-sm btn-outline-danger">Eliminar</a></td></tr> }</tbody></table></div>@if (!Model.Any()) { <div class="text-center text-muted py-4">No hay asistencias registradas.</div> }</div></div>
