@model Asistencia
@{ ViewData["Title"] = "Detalle de asistencia"; }
<div class="card shadow-sm"><div class="card-header"><h2 class="h4 mb-0">Detalle de asistencia</h2></div><div class="card-body"><dl class="row details-list"><dt class="col-sm-3">Cliente</dt><dd class="col-sm-9">@Model.Cliente?.NombreCompleto</dd><dt class="col-sm-3">Entrada</dt><dd class="col-sm-9">@Model.FechaHoraEntrada.ToString("dd/MM/yyyy HH:mm")</dd><dt class="col-sm-3">Salida</dt><dd class="col-sm-9">@(Model.FechaHoraSalida.HasValue ? Model.FechaHoraSalida.Value.ToString("dd/MM/yyyy HH:mm") : "Pendiente")</dd><dt class="col-sm-3">Observación</dt><dd class="col-sm-9">@(string.IsNullOrWhiteSpace(Model.Observacion) ? "-" : Model.Observacion)</dd></dl><a asp-action="Edit" asp-route-id="@Model.AsistenciaId" class="btn btn-primary">Editar</a> <a asp-action="Index" class="btn btn-outline-secondary">Volver</a></div></div>
