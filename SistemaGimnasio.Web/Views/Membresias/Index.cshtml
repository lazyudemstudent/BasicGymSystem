@model IEnumerable<Membresia>
@{ ViewData["Title"] = "Membresías"; }
<div class="card shadow-sm"><div class="card-header d-flex justify-content-between align-items-center"><div><h2 class="h4 mb-0">Membresías</h2><small class="text-muted">Membresías asignadas a los clientes</small></div><a asp-action="Create" class="btn btn-primary">Asignar membresía</a></div><div class="card-body"><div class="table-responsive"><table class="table table-striped table-hover"><thead><tr><th>Cliente</th><th>Plan</th><th>Inicio</th><th>Fin</th><th>Precio</th><th>Estado</th><th></th></tr></thead><tbody>
@foreach (var item in Model) { var vigente = item.Activa && item.FechaFin.Date >= DateTime.Today; <tr><td>@item.Cliente?.NombreCompleto</td><td>@item.TipoMembresia?.Nombre</td><td>@item.FechaInicio.ToString("dd/MM/yyyy")</td><td>@item.FechaFin.ToString("dd/MM/yyyy")</td><td>@item.PrecioAcordado.ToString("C2")</td><td><span class="badge @(vigente ? "bg-success" : "bg-secondary")">@(vigente ? "Activa" : "Vencida/Inactiva")</span></td><td class="action-buttons text-end"><a asp-action="Details" asp-route-id="@item.MembresiaId" class="btn btn-sm btn-outline-secondary">Detalles</a> <a asp-action="Edit" asp-route-id="@item.MembresiaId" class="btn btn-sm btn-outline-primary">Editar</a> <a asp-action="Delete" asp-route-id="@item.MembresiaId" class="btn btn-sm btn-outline-danger">Eliminar</a></td></tr> }
</tbody></table></div>@if (!Model.Any()) { <div class="text-center text-muted py-4">No hay membresías registradas.</div> }</div></div>
