@model Membresia
@{ ViewData["Title"] = "Detalle de membresía"; var vigente = Model.Activa && Model.FechaFin.Date >= DateTime.Today; }
<div class="card shadow-sm"><div class="card-header"><h2 class="h4 mb-0">Detalle de membresía</h2></div><div class="card-body"><dl class="row details-list"><dt class="col-sm-3">Cliente</dt><dd class="col-sm-9">@Model.Cliente?.NombreCompleto</dd><dt class="col-sm-3">Plan</dt><dd class="col-sm-9">@Model.TipoMembresia?.Nombre</dd><dt class="col-sm-3">Fecha de inicio</dt><dd class="col-sm-9">@Model.FechaInicio.ToString("dd/MM/yyyy")</dd><dt class="col-sm-3">Fecha de finalización</dt><dd class="col-sm-9">@Model.FechaFin.ToString("dd/MM/yyyy")</dd><dt class="col-sm-3">Precio acordado</dt><dd class="col-sm-9">@Model.PrecioAcordado.ToString("C2")</dd><dt class="col-sm-3">Estado</dt><dd class="col-sm-9">@(vigente ? "Activa" : "Vencida/Inactiva")</dd><dt class="col-sm-3">Pagos registrados</dt><dd class="col-sm-9">@Model.Pagos.Count</dd></dl><a asp-action="Edit" asp-route-id="@Model.MembresiaId" class="btn btn-primary">Editar</a> <a asp-action="Index" class="btn btn-outline-secondary">Volver</a></div></div>
